# EditorConfig — enforces the house style in code-policy.md
root = true

[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{cs,csx}]
indent_size = 4

[*.{json,yml,yaml,md}]
indent_size = 2

[*.cs]
# --- Standing preference: use `this.`, never `_field` prefixes ---
dotnet_style_qualification_for_field = true:warning
dotnet_style_qualification_for_property = true:warning
dotnet_style_qualification_for_method = true:warning
dotnet_style_qualification_for_event = true:warning

# Naming: no leading-underscore fields; instance fields are camelCase and accessed via `this.`
dotnet_naming_rule.instance_fields_camel_case.severity = warning
dotnet_naming_rule.instance_fields_camel_case.symbols = instance_fields
dotnet_naming_rule.instance_fields_camel_case.style = camel_case_style
dotnet_naming_symbols.instance_fields.applicable_kinds = field
dotnet_naming_symbols.instance_fields.applicable_accessibilities = private, protected, internal, protected_internal, private_protected
dotnet_naming_style.camel_case_style.capitalization = camel_case

# Clean Code leanings
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion
csharp_prefer_braces = true:warning
dotnet_style_readonly_field = true:suggestion
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
dotnet_sort_system_directives_first = true
